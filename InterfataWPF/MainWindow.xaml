<Window x:Class="InterfataWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterfataWPF"
        mc:Ignorable="d"
        Title="Sistem Gestiune Cinema" Height="400" Width="500" WindowStartupLocation="CenterScreen">
    <Grid Background="#F0F2F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="MENIU PRINCIPAL" FontSize="26" FontWeight="Bold" Margin="0,0,0,40" Foreground="#2C3E50"/>

            <Button Content="GESTIUNE FILME" Width="250" Height="60" Margin="10" Background="#3498DB" Foreground="White" FontWeight="Bold" Click="btnFilme_Click"/>
            <Button Content="GESTIUNE CLIENȚI" Width="250" Height="60" Margin="10" Background="#2ECC71" Foreground="White" FontWeight="Bold" Click="btnClienti_Click"/>

            <TextBlock Text="Tema de casa - Management Cinema" Margin="0,30,0,0" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Window>
