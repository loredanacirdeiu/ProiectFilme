<Window x:Class="InterfataWPF.WindowFilme"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterfataWPF"
        mc:Ignorable="d"
        Title="Gestiune Filme" Height="500" Width="700" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <Label Content="Titlu Film:"/>
            <TextBox x:Name="txtTitlu"/>
            <Label Content="Regizor:"/>
            <TextBox x:Name="txtRegizor" Margin="0,0,0,20"/>
            <Button Content="Adaugă Film" Height="30" Click="btnAdaugaFilm_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgFilme" Grid.Column="1" Margin="15,0,0,0" AutoGenerateColumns="True"/>
    </Grid>
</Window>
